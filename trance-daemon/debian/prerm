#!/bin/sh
# prerm script for trance-daemon
set -e

if [ "$1" = "remove" ] || [ "$1" = "upgrade" ]; then
    echo "=========================================================="
    echo "  Stopping Trance Screensaver Daemon Services..."
    echo "=========================================================="

    # Stop the service for all currently logged-in users
    if command -v loginctl >/dev/null && command -v runuser >/dev/null && command -v systemctl >/dev/null; then
        loginctl list-users --no-legend | while read -r uid user linger state; do
            if [ -n "$user" ] && [ -n "$uid" ]; then
                echo "-> Stopping user session service for: $user (UID: $uid)"
                runuser -u "$user" -- env XDG_RUNTIME_DIR="/run/user/$uid" systemctl --user stop trance-daemon.service || true
            fi
        done
    fi
    echo "  Services stopped successfully."
    echo "=========================================================="
fi

if [ "$1" = "remove" ]; then
    # Disable the user service globally
    if command -v systemctl >/dev/null; then
        systemctl --global disable trance-daemon.service || true
    fi
fi

exit 0
