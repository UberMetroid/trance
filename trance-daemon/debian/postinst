#!/bin/sh
# postinst script for trance-daemon
set -e

if [ "$1" = "configure" ]; then
    # Enable the service globally for all user sessions so it runs automatically on login
    systemctl --global enable trance-daemon.service || true

    # Start/restart the service for all currently logged-in users
    if command -v loginctl >/dev/null && command -v runuser >/dev/null && command -v systemctl >/dev/null; then
        loginctl list-users --no-legend | while read -r uid user linger state; do
            if [ -n "$user" ] && [ -n "$uid" ]; then
                runuser -u "$user" -- env XDG_RUNTIME_DIR="/run/user/$uid" systemctl --user daemon-reload || true
                runuser -u "$user" -- env XDG_RUNTIME_DIR="/run/user/$uid" systemctl --user start trance-daemon.service || true
            fi
        done
    fi
fi

exit 0
